@{
    ViewData["Title"] = "Criar contato";
}

<div class="text-center">
    <h2>Cadastrar novo contato</h2>
</div>

<form>
    <div class="form-group" style="margin: 10px 0;">
        <label for="nome">Nome</label>
        <input type="text" class="form-control" placeholder="Digite o nome do contato">
    </div>
    <div class="form-group" style="margin: 10px 0;">
        <label for="email">Email</label>
        <input type="text" class="form-control" placeholder="Digite o email do contato">
    </div>
    <div class="form-group" style="margin: 10px 0;">
        <label for="contato">Contato</label>
        <input type="text" class="form-control" placeholder="Digite um número de contato">
    </div>
    
    <br/>
    <div style="margin: 10px 0;">
        <button type="submit" class="btn btn-primary w-100">Cadastrar</button>
    </div>
    <div style="margin: 10px 0;">
        <a class="btn btn-secondary w-100" asp-controller="Contato" asp-action="Index" role="button">Voltar</a>
    </div>
    
</form>
