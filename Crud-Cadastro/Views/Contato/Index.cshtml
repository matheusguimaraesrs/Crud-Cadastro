@model List<ContatoModel>
@{
    ViewData["Title"] = "Listagem de contatos";
}

<div class="text-center">
    
    <div class="d-grid gap-2 d-md-flex justify-content-md-start">
        <a class="btn btn-primary" role="button" asp-controller="Contato" asp-action="Criar">Adicionar novo contato</a>
    </div>
    <br/>
    
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" aria-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>    
    }
    else if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" aria-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>    
    }
    
    <h2>Listagem de Contatos</h2>
    <br/>
    
    <table class="table table-striped">
        <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Nome</th>
            <th scope="col">Email</th>
            <th scope="col">Contato</th>
            <th scope="col"></th>
        </tr>
        </thead>
        <tbody>
        
        @if (Model != null && Model.Any())
        {
            foreach (ContatoModel contato in Model)
            {
                <tr>
                    <th scope="row">@contato.Id</th>
                    <td>@contato.Name</td>
                    <td>@contato.Email</td>
                    <td>@contato.Contact</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a
                                role="button"
                                class="btn btn-primary"
                                asp-route-id="@contato.Id"
                                asp-controller="Contato"
                                asp-action="Editar">
                                Editar
                            </a>
                            
                            <a
                                role="button"
                                class="btn btn-danger"
                                asp-route-id="@contato.Id"
                                asp-controller="Contato" 
                                asp-action="Apagar">
                                Apagar
                            </a>
                        </div>
                    </td>
                </tr>
            }
        }
        
        </tbody>
    </table>
    
    <nav aria-label="Navegação de Páginas">
        <ul class="pagination justify-content-center">
            
            <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-currentPage="@(ViewBag.CurrentPage - 1)">
                    Anterior
                </a>
            </li>
            
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-currentPage="@i">
                        @i
                    </a>
                </li>
            }
            
            <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-currentPage="@(ViewBag.CurrentPage + 1)">
                    Próximo
                </a>
            </li>
        </ul>
    </nav>
    
</div>
