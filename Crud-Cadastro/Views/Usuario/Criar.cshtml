@using Crud_Cadastro.Enums
@model UsuarioModel
@{
    ViewData["Title"] = "Criar usuário";
}

<div class="text-center">
    <h2>Cadastrar novo usuário</h2>
</div>

<form asp-controller="Usuario" asp-action="Criar" method="post">
    
    <div class="form-group" style="margin: 10px 0;">
        <label for="nome">Nome</label>
        <input type="text" asp-for="Name" class="form-control" placeholder="Digite o nome do usuário">
        @Html.ValidationMessageFor(x => x.Name)
    </div>
    
    <div class="form-group" style="margin: 10px 0;">
        <label for="email">Email</label>
        <input type="text" asp-for="Email" class="form-control" placeholder="Digite o email do usuário">
        @Html.ValidationMessageFor(x => x.Email)
    </div>
    
    <div class="form-group" style="margin: 10px 0;">
        <label for="login">Login</label>
        <input type="text" asp-for="Login" class="form-control" placeholder="Digite o login de usuário">
        @Html.ValidationMessageFor(x => x.Login)
    </div>
    
    <div class="form-group" style="margin: 10px 0;">
        <label for="login">Perfil</label>
        <select asp-for="Profile" class="form-control">
            <option value="">Selecionar</option>
            <option value="@ProfileEnum.Admin">Admin</option>
            <option value="@ProfileEnum.CommonUser">Usuário</option>
        </select>
        @Html.ValidationMessageFor(x => x.Profile)
    </div>
    
    <div class="form-group" style="margin: 10px 0;">
        <label for="senha">Senha</label>
        <input type="password" asp-for="Password" class="form-control" placeholder="Digite a senha do usuário">
        @Html.ValidationMessageFor(x => x.Password)
    </div>
    
    <br/>
    <div style="margin: 10px 0;">
        <button type="submit" class="btn btn-primary w-100">Cadastrar</button>
    </div>
    <div style="margin: 10px 0;">
        <a class="btn btn-secondary w-100" asp-controller="Usuario" asp-action="Index" role="button">Voltar</a>
    </div>

</form>
